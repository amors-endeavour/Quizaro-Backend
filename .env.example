# Backend Environment Variables
# Copy this file to .env and fill in the values

# Server Port
PORT=4000

# MongoDB Connection String (required)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/quizaro?retryWrites=true&w=majority

# JWT Secret (required - use a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Allowed Origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://quizaro-frontend.vercel.app

# Cloudinary Configuration (for file uploads)
CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret

# Email Configuration (for forgot password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3000
